# ── Application ──────────────────────────────────────────
APP_NAME=AURA AI
APP_VERSION=1.0.0
APP_DESCRIPTION=AI Recruitment Intelligence Platform — Hiring Beyond Keywords.
APP_ENV=development
DEBUG=true

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── AI Model Caching ─────────────────────────────────────
HF_HOME=/app/data/hf_cache

# ── API ──────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE=logs/aura.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days
PYTHONUNBUFFERED=1

# ── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./aura.db

# ── Security ─────────────────────────────────────────────
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
